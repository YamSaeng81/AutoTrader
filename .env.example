# ────────────────────────────────────────────
# 백엔드 (Spring Boot) 환경변수
# 복사 후 실제 값으로 교체: cp .env.example .env
# ────────────────────────────────────────────

# Database
DB_PASSWORD=your_secure_password

# API 인증 토큰 — ApiTokenAuthFilter에서 검증 (미설정 시 서버 시작 실패)
API_AUTH_TOKEN=your-strong-random-token-here

# Redis 비밀번호 — docker-compose.prod.yml Redis와 동일한 값 사용
REDIS_PASSWORD=your_redis_password

# Upbit API (AES-256 암호화된 값)
UPBIT_ACCESS_KEY_ENCRYPTED=encrypted_value_here
UPBIT_SECRET_KEY_ENCRYPTED=encrypted_value_here

# AES-256 암호화 키 (32 bytes)
AES_KEY=your-256-bit-secret-key-minimum-32-chars

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your_chat_id

# Host (운영 서버 IP)
HOST_IP=your_server_ip_or_domain

# DDNS 도메인 (포트포워딩 + DDNS 사용 시, 없으면 빈 값으로 둬도 됨)
DDNS_HOST=yourname.ddns.net

# Grafana 관리자 비밀번호 — 미설정 시 컨테이너 시작 실패
GRAFANA_PASSWORD=your_grafana_password

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token

# 프론트엔드 인증
API_TOKEN=your-api-token
AUTH_PASSWORD=your-auth-password
AUTH_SECRET=your-auth-secret-minimum-32-chars
